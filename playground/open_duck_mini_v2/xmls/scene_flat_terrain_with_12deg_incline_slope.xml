<mujoco model="scene">
    <include file="open_duck_mini_v2.xml"/>

    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
        <rgba haze="0.15 0.25 0.35 1"/>
        <global azimuth="160" elevation="-20"/>
    </visual>

    <asset>
        <texture type="skybox" builtin="gradient" rgb1="1 1 1" rgb2="1 1 1" width="800" height="800"/>
        <texture type="2d" name="groundplane" builtin="checker" mark="edge"
                 rgb1="1 1 1" rgb2="1 1 1" markrgb="0 0 0"
                 width="300" height="300"/>
        <material name="groundplane" texture="groundplane"
                  texuniform="true" texrepeat="5 5" reflectance="0"/>
    </asset>

    <worldbody>
        <!-- flat floor -->
        <body name="floor">
            <geom name="floor" size="0 0 0.01" type="plane"
                  material="groundplane" contype="1" conaffinity="0"
                  priority="1" friction="0.6" condim="3"/>
        </body>

        <!-- ADDED: inclined slope in +x direction -->
        <!-- Gentler slope placed closer to the robot -->
        <body name="slope" pos="0.8 0 0">
            <geom name="slope_geom"
                type="box"
                size="1.0 0.5 0.03"     
                pos="0 0 0.03"
                euler="0 -0.2094 0"      
                material="groundplane"
                contype="1"
                conaffinity="1"
                condim="3"
                friction="0.8 0.1 0.1"/>
        </body>



        <!-- ADDED: single step/block further ahead -->
        <body name="step" pos="3.2 0 0.1">
            <!-- half-size: 0.3 (x), 0.5 (y), 0.1 (z) → 0.2m tall step -->
            <geom name="step_geom"
                  type="box"
                  size="0.3 0.5 0.1"
                  material="groundplane"
                  contype="1" conaffinity="0"
                  friction="0.6 0.1 0.1"/>
        </body>
    </worldbody>

    <keyframe>
        <key name="home"
             qpos="
    0 0 0.15
    1 0 0 0
      0.002
        0.053
        -0.63
        1.368
        -0.784
        0
        0
        0
        0
        -0.003
        -0.065
        0.635
        1.379
        -0.796
"
             ctrl="
          0.002
        0.053
        -0.63
        1.368
        -0.784
        0
        0
        0
        0
        -0.003
        -0.065
        0.635
        1.379
        -0.796
          "/>
    </keyframe>
</mujoco>
